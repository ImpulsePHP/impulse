{
  "name": "impulsephp/project_test",
  "type": "project",
  "require": {
    "php": ">=8.2",
    "ext-dom": "*",
    "ext-libxml": "*",
    "ext-openssl": "*",
    "impulsephp/core": "1.*",
    "impulsephp/js": "1.*",
    "impulsephp/translation": "1.*",
    "illuminate/view": "^12.19",
    "tedivm/jshrink": "^1.7"
  },
  "require-dev": {
    "roave/security-advisories": "dev-latest"
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "scripts": {
    "post-install-cmd": [
      "@composer dump-autoload",
      "ln -sf $(pwd)/vendor/impulsephp/js/dist/impulse.js public/impulse.js",
      "ln -sf $(pwd)/vendor/impulsephp/js/dist/impulse.js.map public/impulse.js.map"
    ]
  }
}
