{
  "name": "impulsephp/project_test",
  "type": "project",
  "require": {
    "php": ">=8.2",
    "ext-dom": "*",
    "ext-libxml": "*",
    "ext-openssl": "*",
    "impulsephp/core": "*",
    "impulsephp/js": "*",
    "impulsephp/translation": "*",
    "impulsephp/validator": "*",
    "impulsephp/ui": "*",
    "impulsephp/database": "*",
    "impulsephp/auth": "*",
    "illuminate/view": "^12.19",
    "tedivm/jshrink": "^1.7"
  },
  "require-dev": {
    "roave/security-advisories": "dev-latest",
    "impulsephp/story": "*"
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "repositories": [
    {
      "type": "path",
      "url": "../core"
    },
    {
      "type": "path",
      "url": "../js"
    },
    {
      "type": "path",
      "url": "../translation"
    },
    {
      "type": "path",
      "url": "../validator"
    },
    {
      "type": "path",
      "url": "../story"
    },
    {
      "type": "path",
      "url": "../ui"
    },
    {
      "type": "path",
      "url": "../database"
    },
    {
      "type": "path",
      "url": "../auth"
    }
  ],
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "scripts": {
    "post-install-cmd": [
      "@composer dump-autoload",
      "ln -sf $(pwd)/vendor/impulsephp/js/dist/impulse.js public/impulse.js",
      "ln -sf $(pwd)/vendor/impulsephp/js/dist/impulse.js.map public/impulse.js.map"
    ]
  }
}
