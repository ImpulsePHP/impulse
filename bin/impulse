#!/usr/bin/env php
<?php

require __DIR__ . '/../vendor/autoload.php';

use Impulse\Core\Console\MakeComponentCommand;
use Impulse\Core\Console\MakePageCommand;
use Impulse\Core\Console\MakeRendererCommand;
use Impulse\Core\Console\RendererConfigureCommand;
use Impulse\Fixtures\Console\MakeFixtureCommand;
use Impulse\Fixtures\Console\RunFixturesCommand;
use Symfony\Component\Console\Application;

$app = new Application('Impulse CLI', '1.0.0');
$app->addCommand(new RendererConfigureCommand());
$app->addCommand(new MakeRendererCommand());
$app->addCommand(new MakeComponentCommand());
$app->addCommand(new MakePageCommand());
$app->addCommand(new MakeFixtureCommand());
$app->addCommand(new RunFixturesCommand());

try {
    $app->run();
} catch (Exception $e) {
    throw new RuntimeException($e->getMessage());
}
